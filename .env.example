# ============================================================
# ParkPlatz App — Environment Variables
# ============================================================
# ANLEITUNG:
# 1. Diese Datei kopieren: cp .env.example .env
# 2. In der .env-Datei die echten Keys eintragen
# 3. Die .env-Datei NIEMALS committen (ist in .gitignore)
# ============================================================

# Google Maps — https://console.cloud.google.com
# Benötigt: "Maps SDK for Android" + "Maps SDK for iOS" aktiviert
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Stripe — https://dashboard.stripe.com/apikeys
# NUR den "Publishable Key" (pk_test_...) eintragen, NICHT den Secret Key!
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY

# PayPal — https://developer.paypal.com/dashboard/applications
# NUR die "Client ID", NICHT das "Client Secret"!
EXPO_PUBLIC_PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID

# IDnow — Von IDnow bereitgestellt (nur bei echtem Vertrag)
EXPO_PUBLIC_IDNOW_COMPANY_ID=YOUR_IDNOW_COMPANY_ID

# Backend API URL
EXPO_PUBLIC_API_BASE_URL=https://api.parkplatz.example.com/v1
